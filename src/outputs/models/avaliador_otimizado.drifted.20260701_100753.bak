      },
      {
        "prefix": "Manteve Regras Criticas:",
        "description": "True se nenhuma regra comportamental vital (inclusive as regras adicionais) foi omitida. False caso contrário."
      },
      {
        "prefix": "Nota Clareza:",
        "description": "Nota de 0 a 100 avaliando se a instrução é clara e direta."
      },
      {
        "prefix": "Nota Formatacao:",
        "description": "Nota de 0 a 100 avaliando o uso de markdown, listas e negritos."
      },
      {
        "prefix": "Nota Robustez:",
        "description": "Nota de 0 a 100 avaliando a imunidade a 'lost in the middle' e ambiguidades."
      },
      {
        "prefix": "Nota Densidade Informacional:",
        "description": "Nota de 0 a 100 avaliando a razão sinal/ruído — penaliza verbosidade vazia e repetição sem valor."
      },
      {
        "prefix": "Nota Acionabilidade:",
